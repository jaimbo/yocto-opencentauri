From 7e642e23cb1f421ea8b643f61dce7b3e2a77cd1b Mon Sep 17 00:00:00 2001
From: James Turton <james.turton@gmx.com>
Date: Mon, 9 Mar 2026 23:18:56 +0100
Subject: [PATCH] Use printer data config folder

---
 src/main.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/main.cpp b/src/main.cpp
index 4406d9d..982046a 100644
--- a/src/main.cpp
+++ b/src/main.cpp
@@ -40,7 +40,7 @@ int main(void)
     spdlog::debug("current path {}", std::string(fs::canonical("/proc/self/exe").parent_path()));
 
     Config *conf = Config::get_instance();
-    auto config_path = fs::canonical("/proc/self/exe").parent_path() / "guppyconfig.json";
+    auto config_path = fs::path("/printer_data/config") / "guppyconfig.json";
     conf->init(config_path.string(), "/usr/data/printer_data/thumbnails");
 
     GuppyScreen::init(hal_init);
